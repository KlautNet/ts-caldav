{
  "name": "ts-caldav",
  "version": "0.3.2",
  "description": "A CalDAV client written in TypeScript",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "jest",
    "lint": "eslint",
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "caldav",
    "typescript",
    "calendar",
    "client",
    "caldav-client",
    "ts-caldav",
    "react-native",
    "nodejs"
  ],
  "author": "KlautNet",
  "license": "ISC",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "dependencies": {
    "axios": "^1.13.6",
    "base-64": "^1.0.0",
    "dotenv": "^16.6.1",
    "fast-xml-parser": "^5.5.6",
    "ical.js": "^2.2.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/base-64": "^1.0.2",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.19.15",
    "axios-mock-adapter": "^2.1.0",
    "eslint": "^9.39.4",
    "globals": "^15.15.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  }
}
